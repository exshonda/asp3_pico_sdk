%rename link	picolibc_link
%rename cpp	picolibc_cpp
%rename cc1	picolibc_cc1
%rename cc1plus	picolibc_cc1plus

*cpp:
-isystem %{-picolibc-prefix=*:%*/lib/picolibc/riscv64-unknown-elf/include/; -picolibc-buildtype=*:/usr/lib/picolibc/riscv64-unknown-elf/include/%*; :/usr/lib/picolibc/riscv64-unknown-elf/include} %(picolibc_cpp)

*cc1:
%{!ftls-model:-ftls-model=local-exec} %(picolibc_cc1) 

*cc1plus:
-isystem %{-picolibc-prefix=*:%*/lib/picolibc/riscv64-unknown-elf/include/; -picolibc-buildtype=*:/usr/lib/picolibc/riscv64-unknown-elf/include/%*; :/usr/lib/picolibc/riscv64-unknown-elf/include} %{!ftls-model:-ftls-model=local-exec} %(picolibc_cc1plus)  

*link:
%{DPICOLIBC_DOUBLE_PRINTF_SCANF:--defsym=vfprintf=__d_vfprintf} %{DPICOLIBC_DOUBLE_PRINTF_SCANF:--defsym=vfscanf=__d_vfscanf} %{DPICOLIBC_FLOAT_PRINTF_SCANF:--defsym=vfprintf=__f_vfprintf} %{DPICOLIBC_FLOAT_PRINTF_SCANF:--defsym=vfscanf=__f_vfscanf} %{DPICOLIBC_LONG_LONG_PRINTF_SCANF:--defsym=vfprintf=__l_vfprintf} %{DPICOLIBC_LONG_LONG_PRINTF_SCANF:--defsym=vfscanf=__l_vfscanf} %{DPICOLIBC_INTEGER_PRINTF_SCANF:--defsym=vfprintf=__i_vfprintf} %{DPICOLIBC_INTEGER_PRINTF_SCANF:--defsym=vfscanf=__i_vfscanf} %{DPICOLIBC_MINIMAL_PRINTF_SCANF:--defsym=vfprintf=__m_vfprintf} %{DPICOLIBC_MINIMAL_PRINTF_SCANF:--defsym=vfscanf=__m_vfscanf} -L%{-picolibc-prefix=*:%*/lib/picolibc/riscv64-unknown-elf/lib/%M; -picolibc-buildtype=*:/usr/lib/picolibc/riscv64-unknown-elf/lib/%*/%M; :/usr/lib/picolibc/riscv64-unknown-elf/lib/%M} -L%{-picolibc-prefix=*:%*/lib/picolibc/riscv64-unknown-elf/lib; -picolibc-buildtype=*:/usr/lib/picolibc/riscv64-unknown-elf/lib/%*; :/usr/lib/picolibc/riscv64-unknown-elf/lib} %(picolibc_link)

*lib:
--start-group %(libgcc)  -lc %{-oslib=*:-l%*} --end-group

*endfile:


*startfile:
%{-picolibc-prefix=*:%*/lib/picolibc/riscv64-unknown-elf/lib/%M/%{-crt0=*:crt0-%*%O%s; :crt0%O%s}; -picolibc-buildtype=*:/usr/lib/picolibc/riscv64-unknown-elf/lib/%*/%M/%{-crt0=*:crt0-%*%O%s; :crt0%O%s}; :/usr/lib/picolibc/riscv64-unknown-elf/lib/%M/%{-crt0=*:crt0-%*%O%s; :crt0%O%s}} 

